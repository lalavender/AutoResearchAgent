# ============================================================
# AutoResearchAgent 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- DeepSeek API（必填）---
# API Key，从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=

# --- DeepSeek 模型（可选，以下为默认值）---
# Flash 模型 — 用于规划、搜索、提取、缺口分析（快速、低成本）
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
# Pro 模型 — 用于最终报告生成（深度推理、高质量）
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
# API 地址（默认官方地址，一般无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- 服务器配置（可选）---
# 服务端口，默认 9000
# PORT=9000
# 服务地址，默认 0.0.0.0
# HOST=0.0.0.0

# --- 研究参数默认值（可选，可在前端覆盖）---
# 最大迭代次数，默认 3
# MAX_ITERATIONS=3
# 每轮最大子问题数，默认 2
# MAX_QUESTIONS_PER_ROUND=2
# 单节点超时（秒），默认 120
# NODE_TIMEOUT=120
